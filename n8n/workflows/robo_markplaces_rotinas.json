      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        220,
        120
      ]
    },
    {
      "parameters": {
        "url": "={{$env.ROBO_API_BASE_URL || 'http://localhost:5000'}}/marketplaces/keepalive",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"limite_dias_sem_acesso\": Number($env.ROBO_KEEPALIVE_DIAS || 5)}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "http-keepalive",
      "name": "HTTP Keepalive",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        120
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "cron-algoritmo",
      "name": "Cron Algoritmo",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        320
      ]
    },
    {
      "parameters": {
        "url": "={{$env.ROBO_API_BASE_URL || 'http://localhost:5000'}}/marketplaces/algoritmo/ajustar",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"alertar_quando_atencao\": ($env.ROBO_ALERTAR_ATENCAO || 'false') === 'true'}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "http-algoritmo",
      "name": "HTTP Algoritmo",
