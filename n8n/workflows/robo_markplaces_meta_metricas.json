{
  "name": "Robo-Markplaces - Meta Métricas",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "cron-meta-metricas",
      "name": "Cron Meta Metricas",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        220
      ]
    },
    {
      "parameters": {
        "url": "={{$env.ROBO_API_BASE_URL || 'http://localhost:5000'}}/meta/campanhas/validar",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"alertar_quando_atencao\": ($env.ROBO_ALERTAR_ATENCAO || 'false') === 'true', \"periodo_dias\": 1}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "http-meta-metricas",
      "name": "HTTP Meta Metricas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        520,
        220
      ]
    }
  ],
  "connections": {
    "Cron Meta Metricas": {
      "main": [
        [
          {
            "node": "HTTP Meta Metricas",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {},
  "active": false
}
